# ─── Supabase ────────────────────────────────────────────────────────────────
# Project URL (safe to expose — used in browser client)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co

# Anon / public key (safe to expose — governed by RLS policies)
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Service role key (SECRET — server-only, bypasses RLS)
SUPABASE_SERVICE_ROLE_KEY=

# ─── Paystack ────────────────────────────────────────────────────────────────
# Secret key for server-side API calls and webhook verification (SECRET)
PAYSTACK_SECRET_KEY=

# ─── Admin Auth ──────────────────────────────────────────────────────────────
# Password for /admin routes — stored in httpOnly cookie (SECRET)
ADMIN_PASSWORD=change_me_to_a_strong_password

# Secret used to sign admin session cookies.
# Use a long random value in production. Falls back to ADMIN_PASSWORD if omitted.
ADMIN_SESSION_SECRET=change_me_to_a_long_random_secret

# ─── App URL ─────────────────────────────────────────────────────────────────
# Used for Paystack callback redirect
NEXT_PUBLIC_SITE_URL=https://your-domain.com
