# ─── Supabase ────────────────────────────────────────────────────────────────
# Project URL (safe to expose — used in browser client)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co

# Anon / public key (safe to expose — governed by RLS policies)
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# Service role key (SECRET — server-only, bypasses RLS)
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# ─── Paystack ────────────────────────────────────────────────────────────────
# Secret key for server-side API calls and webhook verification (SECRET)
PAYSTACK_SECRET_KEY=sk_live_your_paystack_secret_key

# ─── Admin Auth ──────────────────────────────────────────────────────────────
# Password for /admin routes — stored in httpOnly cookie (SECRET)
ADMIN_PASSWORD=FragNaija2026PubgMobile

# ─── App URL ─────────────────────────────────────────────────────────────────
# Used for Paystack callback redirect
NEXT_PUBLIC_SITE_URL=https://your-domain.com
